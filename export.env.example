# Export script environment variables
# Copy this file to export.env and update with your local PostgreSQL setup

DB_HOST=localhost
DB_PORT=5400
DB_NAME=budget_buddy
DB_USERNAME=postgres
DB_PASSWORD=your_actual_password_here
DB_SSLMODE=disable
DB_DEBUG=false

# Instructions:
# 1. Copy this file: cp export.env.example export.env
# 2. Update DB_PASSWORD with your actual PostgreSQL password
# 3. Update other values if your database setup is different
# 4. Run: go run export_local_data.go
